# Streamlit secrets & credentials (never commit)
.streamlit/secrets.toml
.streamlit/credentials.toml

# Claude Code local config
.mcp.json
.claude/settings.local.json
.claude/settings.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Pre-downloaded ML models (run tools/setup_models.py to populate)
tools/models/

# Runtime data (generated at runtime, not source code)
data/downloads/
data/frames/
data/*.mp4
data/*.wav
data/*.jpg
data/*.png
data/*.json

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
