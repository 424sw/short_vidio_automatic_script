# Streamlit secrets & credentials (never commit)
.streamlit/secrets.toml
.streamlit/credentials.toml

# Claude Code local config / runtime
.mcp.json
.claude/settings.local.json
.claude/settings.json
.claude/scheduled_tasks.json
.claude/worktrees/

# Python cache
__pycache__/
*.pyc
*.pyo

# Pre-downloaded ML models — 已跟随代码部署，无需服务器下载
# tools/models/

# Runtime data — all session subdirs + any files under data/
# Session dirs like data/<session_id>/ contain frames, audio, downloads, etc.
data/*/
data/*.mp4
data/*.wav
data/*.jpg
data/*.png
data/*.json

# Runtime marker files (never commit)
data/.cleanup_done
data/.expiry_queue
data/.expiry_queue.tmp

# OS files
.DS_Store
Thumbs.db

# Linter
.ruff_cache/

# IDE
.vscode/
.idea/
